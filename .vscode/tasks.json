{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "generate all dsc archives",
            "type": "shell",
            "command": "${workspaceFolder}${/}setup${/}New-DSCArchive.ps1",
            "args": [
                "-vmName",
                "*",
                "-dscFolderPath",
                "'${workspaceFolder}${/}sharepoint-adfs-full'"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "generate dsc archive for current file",
            "type": "shell",
            "command": "${workspaceFolder}${/}setup${/}New-DSCArchive.ps1",
            "args": [
                "-vmName",
                "${fileBasenameNoExtension}",
                "-dscFolderPath",
                "'${fileWorkspaceFolder}'"
            ],
            "problemMatcher": []
        },
        {
            "label": "generate dsc archive for specified file",
            "type": "shell",
            "command": "${workspaceFolder}${/}setup${/}New-DSCArchive.ps1",
            "args": [
                "-vmName",
                "${input:vmName}",
                "-dscFolderPath",
                "'${fileWorkspaceFolder}'"
            ],
            "problemMatcher": []
        },
        {
            "label": "install missing modules locally",
            "type": "shell",
            "command": "${workspaceFolder}${/}setup${/}Install-Modules.ps1",
            "args": [
                "-localProjectPath",
                "'${workspaceFolder}'",
                "-vmName",
                "*",
                "-copyCustomizedModules",
                "${input:copyCustomizedModules}"
            ],
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "type": "promptString",
            "id": "vmName",
            "description": "Name of the VM for which to generate the DSC archive.",
            "default": "spse-main"
        },
        {
            "type": "pickString",
            "id": "copyCustomizedModules",
            "description": "Copy customized modules (0: No, 1: Yes).",
            "options": ["1", "0"],
            "default": "0"
        }
    ]
}