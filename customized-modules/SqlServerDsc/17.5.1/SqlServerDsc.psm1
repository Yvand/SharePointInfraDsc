                $previousErrorActionPreference = $ErrorActionPreference
                $ErrorActionPreference = 'Stop'
                $sqlDatabaseObject = $ServerObject | Get-SqlDscDatabase -Name $Name -Refresh:$Refresh -ErrorAction 'Stop'
