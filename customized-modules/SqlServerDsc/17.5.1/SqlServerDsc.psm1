                $writeErrorParameters = @{
                    Message      = $missingDatabaseMessage
                    Category     = 'ObjectNotFound'
                    ErrorId      = 'GSDD0001' # cspell: disable-line
                    TargetObject = $Name
                }

                Write-Error @writeErrorParameters
            }
            else
